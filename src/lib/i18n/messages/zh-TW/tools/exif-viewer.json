      "faq": {
        "what-is-exif-data": {
          "question": "照片中的 EXIF 資料是什麼？",
          "answer": "EXIF（Exchangeable Image File Format）是相機自動嵌入照片的後設資料，包含相機設定（光圈、快門速度、ISO）、相機與鏡頭型號、日期時間，有時還會記錄 GPS 座標。"
        },
        "how-to-read-histogram": {
          "question": "如何解讀照片的直方圖？",
          "answer": "直方圖顯示影像中亮度的分布，從陰影（左側）到高光（右側）。曝光良好的照片通常橫跨整個範圍而兩端都沒有溢出，但理想的形狀仍取決於場景本身。"
        },
        "does-exif-contain-location": {
          "question": "EXIF 資料會包含我的位置嗎？",
          "answer": "若您的相機或手機開啟 GPS，EXIF 可能會記錄拍攝地點的精確座標。在網路分享前請留意這點 — 許多社群平台會移除 EXIF，但並非全部都會。"
        }
      }
